{
  "projectName": "DattSoap Flutter App",
  "framework": "Flutter",
  "language": "Dart",
  "platforms": ["android", "ios", "web", "windows", "linux", "macos"],
  "entryPoint": "lib/main.dart",
  "routing": {
    "package": "go_router",
    "routerFile": "lib/routers/app_router.dart",
    "initialLocation": "/splash",
    "authFlow": {
      "splash": "/splash",
      "login": "/login",
      "postLoginRedirect": "role-based landingPath from Firestore users collection"
    }
  },
  "auth": {
    "provider": "lib/providers/auth/auth_provider.dart",
    "loginScreen": "lib/screens/auth/login_screen.dart",
    "method": "Firebase Auth (email/password), Firestore for roles",
    "roles": ["admin", "owner", "storeIncharge", "salesman", "fuelIncharge", "driver", "productionSupervisor", "productionManager", "bhattiSupervisor", "Manager"]
  },
  "mainModules": [
    "Dashboard",
    "Sales (new sale, sales history)",
    "Inventory (tanks, stock, purchase orders, opening stock)",
    "Dispatch (trips, dealer dispatch)",
    "Production (dashboard, batches, cutting)",
    "Bhatti (dashboard, cooking, supervisor)",
    "Reports (salesman, GST, returns, stock, production, etc.)",
    "Settings (general, company profile, audit logs, roles, currencies, etc.)",
    "Management (users, products, dealers, sales targets, schemes, etc.)",
    "HR (dashboard, employees, attendance, payroll)",
    "Customers / Business Partners",
    "Returns (management, new return, salesman returns)",
    "Payments",
    "Fuel (log, stock, history)",
    "Vehicles (management, add, diesel/maintenance/tyre logs)",
    "Driver (duty, trips, route, mileage)",
    "Tasks (kanban)",
    "GPS, Map (customers, route planner)",
    "Sync (conflicts, analytics)"
  ],
  "keyPaths": [
    "/",
    "/splash",
    "/login",
    "/dashboard",
    "/dashboard/sales/new",
    "/dashboard/sales",
    "/dashboard/inventory",
    "/dashboard/inventory/tanks",
    "/dashboard/dispatch",
    "/dashboard/reports",
    "/dashboard/settings",
    "/dashboard/management",
    "/dashboard/hr",
    "/dashboard/tasks",
    "/dashboard/business-partners"
  ],
  "testing": {
    "type": "frontend",
    "testScope": "codebase",
    "needLogin": true,
    "localPort": 8080
  }
}
